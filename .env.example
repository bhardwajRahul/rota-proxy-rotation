# ============================================================
# Rota — environment configuration
#
# EVERYTHING HAS SENSIBLE DEFAULTS. For a local run you don't even
# need this file — `docker compose up -d` works out of the box.
# Copy to .env only to change something:  cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# COMMON — the few things people actually change
# ------------------------------------------------------------

# Where the web UI is served. Leave as-is for local (http://localhost).
# For production set a domain to get automatic HTTPS, e.g. rota.example.com
# SITE_ADDRESS=rota.example.com

# Admin login. Leave the password blank to auto-generate a strong one on first
# boot — it's printed in the core logs (`make password`). Set it to pick your own.
ROTA_ADMIN_USER=admin
# ROTA_ADMIN_PASSWORD=

# Port the actual proxy listens on (what your clients connect to).
PROXY_PORT=8000

# ------------------------------------------------------------
# ADVANCED — safe to ignore for most setups
# ------------------------------------------------------------

# Web entry ports (Caddy). Change if 80/443 are taken.
HTTP_PORT=80
HTTPS_PORT=443

# Database (TimescaleDB, internal to the compose network).
DB_HOST=timescaledb
DB_PORT=5432
DB_USER=rota
DB_PASSWORD=rota_password
DB_NAME=rota
DB_SSLMODE=disable

# Logging: debug | info | warn | error
LOG_LEVEL=info

# CORS. Irrelevant behind the bundled reverse proxy (dashboard is same-origin).
# Set to a comma-separated allowlist only if you expose the API cross-origin.
CORS_ALLOWED_ORIGINS=*

# Trust X-Forwarded-For / X-Real-IP for the login rate limiter's per-IP tracking.
# true when behind a trusted reverse proxy (the bundled Caddy sets it to true);
# set false if you expose the API directly, so the headers can't be spoofed to
# bypass per-IP login throttling.
TRUST_PROXY_HEADERS=true

# Direct dashboard API override — normally EMPTY (same-origin via Caddy).
# Only set for a custom deployment that bypasses the reverse proxy.
# NEXT_PUBLIC_API_URL=

# Auth brute-force protection.
# Per-IP: block after N failures within a window, for a cooldown.
AUTH_IP_MAX_ATTEMPTS=10
AUTH_IP_WINDOW_MINUTES=10
AUTH_IP_BLOCK_MINUTES=30
# Global: lock the login endpoint if total attempts/min exceed the cap.
AUTH_GLOBAL_MAX_PER_MINUTE=1000
AUTH_GLOBAL_LOCKOUT_MINUTES=1
